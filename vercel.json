{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cron/daily-brief", "schedule": "30 12 * * *" },
    { "path": "/api/cron/job-scout", "schedule": "0 13 * * 1" },
    { "path": "/api/cron/github-scout", "schedule": "0 13 * * 1" }
  ],
  "functions": {
    "app/api/**/*": { "maxDuration": 60 }
  }
}
