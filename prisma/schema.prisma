// Hermes OS — starter schema. Tables mirror docs/HERMES_OS_MASTER_SPEC.md section 8.
// Uses Turso (libSQL) via the driver adapter at runtime; see src/lib/db.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String               @id @default(cuid())
  primaryEmail        String               @unique
  name                String?
  picture             String?
  createdAt           DateTime             @default(now())
  accounts            GoogleAccount[]
  briefs              DailyBrief[]
  tasks               Task[]
  approvals           ApprovalAction[]
  usage               ModelUsage[]
  memories            Memory[]
  financeEntries      FinanceEntry[]
  jobListings         JobListing[]
  jobLeads            JobLead[]
  masterResume        MasterResume?
  chatMessages        ChatMessage[]
  trackedApps         TrackedApplication[]
  auditLogs           AuditLog[]
  agentTasks          AgentTask[]
  executionRuns       ExecutionRun[]
  engineeringTasks    EngineeringTask[]
  emailCorrespondents EmailCorrespondent[]
  userSkills          UserSkill[]
  agentEnvelopes      AgentEnvelope[]
  agentWakeups        AgentWakeup[]
  capabilityGaps      CapabilityGap[]
}

model GoogleAccount {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleSub      String
  email          String
  label          String    @default("Other") // Work | UT | Personal | Other
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime
  scopes         String    @default("") // space-separated
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  lastSyncedAt   DateTime?
  lastSyncStatus String?
  lastError      String?

  @@unique([userId, googleSub])
}

model EmailCorrespondent {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountEmail  String
  email         String
  displayName   String?
  sentCount     Int       @default(0)
  firstSentAt   DateTime?
  lastSentAt    DateTime?
  lastScannedAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, accountEmail, email])
  @@index([userId, email])
  @@index([userId, lastScannedAt])
}

model AgentRun {
  id            String   @id @default(cuid())
  agentName     String // canonical Hermes agent key; see src/lib/agent-roster.ts
  inputSummary  String?
  outputSummary String?
  modelProvider String?
  status        String   @default("completed")
  createdAt     DateTime @default(now())

  @@index([agentName, createdAt])
  @@index([createdAt])
}

model DailyBrief {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  briefDate DateTime
  content   String // JSON
  createdAt DateTime @default(now())

  @@unique([userId, briefDate])
}

model Task {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  source        String?
  sourceRef     String?
  title         String
  description   String?
  dueAt         DateTime?
  status        String    @default("open")
  priority      String    @default("medium")
  assignedAgent String? // canonical Hermes agent key; see src/lib/agent-roster.ts
  delegatedBy   String? // "osman" if user-assigned, or the agent name that handed it off
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
}

model ApprovalAction {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionType String // draft_email|send_email|create_event|create_task|label_email
  payload    String // JSON
  status     String    @default("pending") // pending|approved|rejected|executed
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([userId, status])
  @@index([userId, createdAt])
}

model ModelUsage {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  taskType     String?
  dataClass    String? // PUBLIC|PERSONAL|PRIVATE|SECRET
  inputTokens  Int?
  outputTokens Int?
  estCostUsd   Float?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([provider, createdAt])
}

model Memory {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fact       String
  source     String?
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
}

// Plutus's own ledger — manual entries Osman logs himself. Plutus only ever
// reads/aggregates/warns from this; it never moves money or makes transactions
// (no payment-API integration exists or is planned per master-spec section 3).
model FinanceEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String // income|expense|debt_balance|debt_payment
  category    String?
  amountUsd   Float
  description String?
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}

// Athena's application tracker — Osman (or github-scout/job-scout, once those
// land approved suggestions) logs roles here. Athena scores fit and tracks
// status; it never submits an application — that goes through the approval
// queue as an "apply_to_job" action per master-spec section 3.
model JobListing {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  company   String
  url       String?
  source    String    @default("manual") // manual|github-scout|job-scout
  status    String    @default("interested") // interested|applied|interview|offer|rejected|archived
  fitScore  Int?
  notes     String?
  postedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model DecisionLog {
  id        String   @id @default(cuid())
  title     String
  decision  String
  reason    String?
  createdAt DateTime @default(now())
}

// ── Job Scout pipeline ────────────────────────────────────────────────────────
// JobLead: one parsed job from a Gmail job-alert email.
// ApplicationKit: generated materials (resume bullets, cover letter, ATS score).
// MasterResume: Osman's seed resume JSON — one record, updated via the dashboard.
// JobScoutRun: audit log for each pipeline execution.

model JobLead {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint    String // SHA-256(company:title:url) — dedupe key
  company        String
  title          String
  location       String?
  url            String?
  rawSnippet     String? // email snippet that surfaced this lead
  jdText         String? // full job description fetched from the posting URL
  source         String          @default("gmail-alert") // gmail-alert|manual
  fitScore       Int?
  fitReason      String?
  status         String          @default("new") // new|scored|kit_ready|archived
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  applicationKit ApplicationKit?

  @@unique([userId, fingerprint])
  @@index([userId, status])
}

model ApplicationKit {
  id             String   @id @default(cuid())
  jobLeadId      String   @unique
  jobLead        JobLead  @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  resumeBullets  String? // LLM-tailored bullet points
  coverLetter    String? // LLM-drafted cover letter (never auto-sent)
  recruiterEmail String? // Hunter.io enriched email
  gmailDraftId   String? // set after approval executes the Gmail draft
  atsScore       Int?
  atsFeedback    String? // missing keywords
  status         String   @default("pending") // pending|ready|draft_queued
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MasterResume {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String // JSON blob — seed master resume
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model JobScoutRun {
  id            String   @id @default(cuid())
  emailsScanned Int      @default(0)
  leadsFound    Int      @default(0)
  leadsScored   Int      @default(0)
  kitsBuilt     Int      @default(0)
  draftsQueued  Int      @default(0)
  digestSent    Boolean  @default(false)
  errors        String? // JSON array of error strings
  createdAt     DateTime @default(now())
}

// Persisted "talk to Hermes" history — shared by the dashboard chat panel and
// the Telegram bridge (both call the same Hermes.routeMessage() core, and both
// log here, so the conversation reads as one continuous thread either way).
// Pure log; Hermes does not load this as model context — each message is
// routed independently via routeMessage's own keyword-matched data lookups.
model ChatMessage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String // "user" | "assistant"
  content     String
  channel     String   @default("dashboard") // "dashboard" | "telegram"
  targetAgent String? // null = general Hermes thread; else canonical key from src/lib/agent-roster.ts
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, targetAgent, createdAt])
}

// ── Job Application Tracker ───────────────────────────────────────────────────
// Closed-loop tracker for applications Osman has actually submitted (or received
// email evidence of). Separate from JobListing (Athena's interest list) and
// JobLead (job-scout pipeline). Source of truth for "where did I apply".
// Status machine: Applied → Needs Reply / Interview / Waiting → Rejected / Offer
// Detection: Gmail sweep (daily cron + backfill) + manual "log this job" command.

model TrackedApplication {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint      String // SHA-256(company.lower + title.lower) — dedupe key
  companyName      String
  jobTitle         String
  applicationDate  DateTime  @default(now())
  source           String    @default("Other") // Gmail|Manual Entry|Handshake|Indeed|LinkedIn|Company Website|Other
  status           String    @default("Unknown") // Applied|Needs Reply|Interview|Waiting|Rejected|Offer|Unknown
  contactName      String?
  contactEmail     String?
  emailSubject     String?
  jobUrl           String?
  location         String?
  notes            String?
  nextFollowUpDate DateTime?
  gmailMessageId   String? // source Gmail message id for linkback
  lastUpdatedAt    DateTime  @updatedAt
  createdAt        DateTime  @default(now())

  @@unique([userId, fingerprint])
  @@index([userId, status])
  @@index([userId, lastUpdatedAt])
}

// Execution registry — every task Hermes claims to be running must have a row here.
// Hard rule: Hermes may only say "done" / "completed" / "build passed" if a row
// with status="completed" exists. Status questions consult this table first.
model AgentTask {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  title       String
  description String
  status      String   @default("queued") // queued | running | blocked | completed | failed
  files       String? // JSON array of file paths involved
  result      String? // summary of the outcome, set on completed/failed
  error       String? // error message, set on failed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([projectId])
}

// Project tracker rows are also used by legacy libSQL helpers in memory-context
// and local-builder. Keep this model column-complete and relation-light so
// db push can align Prisma without rebuilding live runtime tables.
model Project {
  id                     String    @id @default(cuid())
  userId                 String
  projectName            String
  description            String?
  route                  String?
  status                 String    @default("planning")
  latestInstruction      String?
  assignedAgent          String?
  localFolderPath        String?
  localBuildLog          String?
  localBuildError        String?
  localDevUrl            String?
  localDevPid            Int?
  localPreviewStatus     String?
  localPreviewCheckedAt  String?
  localResearchBrief     String?
  localDesignReview      String?
  localPolishReview      String?
  designScore            Int?
  fuguGateStatus         String?
  fuguGateScore          Int?
  fuguGateReview         String?
  fuguGateReviewedAt     String?
  fuguGateOverrideReason String?
  fuguPolishStatus       String?
  localQaStatus          String?
  localQaChecklist       String?
  phase                  String    @default("planning")
  latestPlanId           String?
  requestFingerprint     String?
  completionEvidence     String?
  completedAt            DateTime?
  createdAt              DateTime?
  updatedAt              DateTime?

  @@index([userId, status])
  @@index([userId, phase])
  @@index([userId, updatedAt])
  @@index([route])
}

model ProjectTask {
  id                   String    @id @default(cuid())
  projectId            String
  userId               String?
  parentTaskId         String?
  goalId               String?
  title                String
  description          String?
  status               String    @default("backlog")
  priority             String    @default("medium")
  assignedAgent        String?
  responsibleAgent     String?
  acceptanceCriteria   String?
  requiredCapabilities String?
  outputContract       String?
  claimedRunId         String?
  activeRunId          String?
  executionLockedAt    DateTime?
  attemptCount         Int       @default(0)
  maxAttempts          Int       @default(3)
  blockedReason        String?
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  nextStep             String?
  createdAt            DateTime?
  updatedAt            DateTime?

  @@index([projectId, status])
  @@index([projectId, updatedAt])
  @@index([assignedAgent, status])
  @@index([parentTaskId])
  @@index([userId, updatedAt])
  @@index([status])
}

model ProjectTaskDependency {
  id             String   @id @default(cuid())
  projectId      String
  taskId         String
  blockingTaskId String
  createdAt      DateTime @default(now())

  @@unique([taskId, blockingTaskId])
  @@index([projectId])
  @@index([blockingTaskId])
}

model ProjectPlan {
  id                   String    @id @default(cuid())
  projectId            String
  revision             Int
  status               String
  body                 String
  decisionSnapshot     String?
  capabilityResolution String?
  requestFingerprint   String
  createdByAgent       String?
  acceptedByUserId     String?
  acceptedAt           DateTime?
  createdAt            DateTime  @default(now())

  @@unique([projectId, revision])
  @@index([projectId, status])
}

model ProjectPlanDecomposition {
  id             String    @id @default(cuid())
  projectId      String
  planId         String
  status         String    @default("in_flight")
  requestedTasks String
  createdTaskIds String
  ownerAgent     String?
  ownerRunId     String?
  fingerprint    String
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@unique([projectId, planId])
  @@index([fingerprint])
}

model ProjectTaskArtifact {
  id             String   @id @default(cuid())
  projectId      String
  projectTaskId  String
  executionRunId String?
  wakeupId       String?
  agentKey       String
  artifactType   String
  title          String
  summary        String?
  content        String?
  safeLocation   String?
  contentHash    String
  source         String
  metadata       String?
  createdAt      DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([projectTaskId])
  @@index([executionRunId])
  @@index([wakeupId])
  @@index([artifactType])
}

model AgentWakeup {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId            String?
  projectTaskId        String?
  agentKey             String
  source               String
  reason               String
  payload              String?
  status               String    @default("queued")
  coalescedCount       Int       @default(0)
  requestedByActorType String?
  requestedByActorId   String?
  idempotencyKey       String?   @unique
  runId                String?
  requestedAt          DateTime  @default(now())
  claimedAt            DateTime?
  finishedAt           DateTime?
  error                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([agentKey, status, requestedAt])
  @@index([projectId, requestedAt])
  @@index([projectTaskId])
}

model CapabilityGap {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId           String
  projectTaskId       String?
  capabilityName      String
  capabilityType      String
  status              String   @default("detected")
  assignedAgent       String?
  selectedCandidateId String?
  resolvedSkillId     String?
  blockedReason       String?
  attemptCount        Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([projectId, status])
  @@index([userId, status])
}

model Skill {
  id                     String   @id @default(cuid())
  skillId                String   @unique
  name                   String
  description            String
  status                 String   @default("draft")
  currentVersionId       String?
  latestValidationStatus String?
  riskClassification     String?
  approvalRequired       Boolean  @default(false)
  rollbackInformation    String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([status])
}

model SkillVersion {
  id                String   @id @default(cuid())
  skillId           String
  version           Int
  definition        String
  executionTool     String?
  ownerAgents       String?
  permissionScope   String?
  validationStatus  String   @default("draft")
  rollbackReference String?
  createdAt         DateTime @default(now())

  @@unique([skillId, version])
  @@index([skillId, validationStatus])
}

model SkillSource {
  id                   String   @id @default(cuid())
  skillId              String
  versionId            String?
  repository           String
  filePath             String
  commitSha            String
  license              String?
  trustLevel           String
  compatibility        String?
  fileInventory        String?
  contentHash          String
  requiredDependencies String?
  requiredCredentials  String?
  permissionScope      String?
  rollbackPlan         String?
  createdAt            DateTime @default(now())

  @@index([skillId])
  @@index([commitSha])
}

model SkillEvaluationCase {
  id        String   @id @default(cuid())
  skillId   String
  versionId String?
  caseType  String
  prompt    String
  expected  String?
  createdAt DateTime @default(now())

  @@index([skillId, caseType])
}

model SkillEvaluationRun {
  id          String   @id @default(cuid())
  skillId     String
  versionId   String?
  status      String
  result      String
  passedCount Int      @default(0)
  failedCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([skillId, createdAt])
}

model AgentSkillAssignment {
  id        String   @id @default(cuid())
  agentKey  String
  skillId   String
  versionId String?
  status    String   @default("active")
  createdAt DateTime @default(now())

  @@unique([agentKey, skillId])
  @@index([agentKey, status])
}

model UserSkill {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId     String
  name        String
  description String
  category    String   @default("workflow")
  definition  String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, skillId])
  @@index([userId, enabled])
  @@index([userId, updatedAt])
}

model ExecutionRun {
  id                      String                @id @default(cuid())
  userId                  String
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId               String?
  taskId                  String?
  parentRunId             String?
  executor                String
  currentPhase            String                @default("queued")
  currentActivity         String?
  startedAt               DateTime              @default(now())
  lastHeartbeatAt         DateTime              @default(now())
  lastMeaningfulEventAt   DateTime              @default(now())
  completedAt             DateTime?
  status                  String                @default("queued")
  lastSafeError           String?
  workerId                String?
  localFolderPath         String?
  fallbackReason          String?
  cancellationRequestedAt DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  events                  ExecutionTraceEvent[]

  @@index([userId, status])
  @@index([userId, startedAt])
  @@index([taskId])
  @@index([projectId])
}

model ExecutionTraceEvent {
  id          String       @id @default(cuid())
  runId       String
  run         ExecutionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  phase       String
  severity    String       @default("info")
  message     String
  source      String
  safeDetails String?
  createdAt   DateTime     @default(now())

  @@index([runId, createdAt])
  @@index([phase, createdAt])
}

model AgentEnvelope {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAgent     String
  toAgent       String?
  envelopeType  String
  payload       String
  status        String    @default("pending")
  correlationId String?
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status, expiresAt])
  @@index([toAgent, status, createdAt])
  @@index([correlationId])
}

model EngineeringTask {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                 String
  repositorySlug        String
  operationType         String
  riskLevel             String
  approvalRequired      Boolean   @default(false)
  status                String    @default("queued")
  correlationId         String?
  executorName          String?
  executorJobId         String?
  resultSummary         String?
  errorReference        String?
  sanitizedError        String?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  // Phase 2 — branch execution
  approvalStatus        String?
  approvedAt            DateTime?
  approvedBy            String?
  branchName            String?
  commitSha             String?
  pullRequestUrl        String?
  implementationSummary String?
  validationResults     String?
  // Phase 3 — deployment
  deployTarget          String?
  deployStatus          String?
  vercelDeploymentId    String?
  deploymentUrl         String?
  deployStartedAt       DateTime?
  deployCompletedAt     DateTime?
  rollbackReference     String?

  @@index([userId, status])
  @@index([userId, createdAt])
}

// Append-only audit trail — every approval, rejection, and sensitive action.
// Never deleted. Used for accountability and incident reconstruction.
model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       String // "approved" | "rejected" | "executed" | "rate_limited" | "auth_failed"
  resourceType String // "ApprovalAction" | "Task" | "ChatMessage" | "MemoryFact"
  resourceId   String? // ID of the affected row
  detail       String? // Human-readable summary, max 500 chars
  ipHash       String? // SHA-256 of IP for abuse detection (not raw IP — privacy)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}
