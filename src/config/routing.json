{
  "_comment": "Hermes reads this to route a request. Match incoming text against `intents` (keyword/substring first, embedding similarity as fallback), pick the route, run its `task` via the dispatcher, using `tools`. Model overrides in `model_routing` win if present in the text.",

  "model_routing": {
    "default": "auto",
    "auto_rule": "local for triage/categorize/summary/retrieve; cloud for resume, cover letter, security analysis, anything sent to a human",
    "overrides": [
      { "phrases": ["use local", "run it locally", "use ollama"], "backend": "ollama" },
      { "phrases": ["use the cloud", "use the big model", "go cloud"], "backend": "cloud_best" },
      { "phrases": ["use claude"], "backend": "anthropic" },
      { "phrases": ["use chatgpt", "use gpt"], "backend": "openai" }
    ]
  },

  "routes": [
    {
      "agent": "iris",
      "intents": ["check my email", "triage", "inbox", "what's in my inbox", "any new email"],
      "task": "iris.triage_email",
      "tools": ["gmail"]
    },
    {
      "agent": "iris",
      "intents": ["reply to", "respond to", "email", "write an email", "draft a message"],
      "task": "iris.draft_replies",
      "tools": ["gmail", "skill:humanizer"]
    },
