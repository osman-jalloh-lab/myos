{
  "id": "build-validation-runner",
  "name": "Build Validation Runner",
  "description": "Run or recommend validation commands after code changes.",
  "category": "build",
  "ownerAgents": [
    "argus"
  ],
  "tags": [
    "build",
    "validation",
    "tests",
    "lint",
    "typecheck",
    "deployment"
  ],
  "safetyClass": "approval_required",
  "source": "hermes-os",
  "purpose": "Run checks after changes and turn failures into specific next steps instead of vague build errors.",
  "whenToUse": [
    "Run tests and build",
    "Run typecheck",
    "Run lint",
    "Run build",
    "Prisma generate",
    "Deployment readiness",
    "Vercel status",
    "Verify changes are safe to ship"
  ],
  "whenNotToUse": [
    "Rewrite an email",
    "Answer HR/I-9 questions",
    "Score a job",
    "Draft a recruiter reply",
    "Create a normal task",
    "Explain something without changing code"
  ],
  "strongSignals": [
    "run tests",
    "run build",
    "run typecheck",
    "run lint",
    "prisma generate",
    "deployment readiness",
    "vercel status",
    "check vercel deployment",
    "vercel deployment",
    "deployment status",
    "is this safe to push",
    "safe to deploy",
    "check deployment",
    "verify validation",
    "validation after changes"
  ],
  "weakSignals": [
    "check build",
    "run checks",
    "validating",
    "readiness",
    "deployment",
    "pipeline"
  ],
  "negativeSignals": [
    "email",
    "i-9",
    "job application",
    "resume",
    "rewrite",
    "calendar",
    "dating text",
    "lease message"
