  "requiredContext": [
    "Commands to run",
    "Latest change set",
    "Environment assumptions"
  ],
  "missingContextQuestions": [
    "Do you want typecheck, lint, tests, and build?",
    "Should this check deployment status as well?"
  ],
  "safetyRules": [
    "Do not run destructive commands unless asked",
    "Never touch secrets or env values while validating",
    "Clearly separate read checks from write-capable deploy steps",
    "Preserve existing approval gates for deploy actions"
  ],
  "outputContract": {
    "format": "Validation report with clear pass/fail outcomes.",
    "mustInclude": [
      "Commands run",
      "Results",
      "Failures",
      "Likely cause",
      "Fix recommendation",
      "Safe to push",
      "Safe to deploy"
    ],
    "mustAvoid": [
      "Vague status",
      "Skipping likely cause",
      "Recommending deploy before failures are explained"
    ]
  },
  "approvalRequiredFor": [
    "deploy steps"
  ],
  "positiveExamples": [
    "Run tests and build.",
    "Run typecheck, lint, tests, and build.",
    "Check Vercel deployment status after this change.",
    "Validate provider setup before deploying.",
    "Is this safe to push?"
  ],
  "negativeExamples": [
    "Rewrite my email to my manager.",
    "Help me answer an I-9 question.",
    "Draft a recruiter follow-up.",
    "Create a task to follow up tomorrow.",
    "Explain how Next.js routing works."
  ],
  "evaluationPrompts": [
    {
      "input": "Run tests and build.",
      "shouldMatch": true,
      "expectedSkill": "build-validation-runner",
      "reason": "Exact validation request.",
      "minimumScore": 90
    },
    {
      "input": "Run typecheck, lint, tests, and build.",
      "shouldMatch": true,
      "expectedSkill": "build-validation-runner",
      "reason": "Full validation pipeline request.",
      "minimumScore": 90
    },
    {
      "input": "Check Vercel deployment.",
      "shouldMatch": true,
      "expectedSkill": "build-validation-runner",
      "reason": "Deployment validation request.",
      "minimumScore": 80
    },
    {
      "input": "Is this safe to push?",
      "shouldMatch": true,
      "expectedSkill": "build-validation-runner",
      "reason": "Validation request with safety intent.",
      "minimumScore": 85
    },
    {
      "input": "Verify validation after changes.",
      "shouldMatch": true,
      "expectedSkill": "build-validation-runner",
