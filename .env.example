# Hermes OS — environment variables
# Set these in Vercel (Project > Settings > Environment Variables) and in .env.local for dev.
# NEVER commit real values.

# --- App / domain ---
HERMES_DOMAIN=hermes.your-domain.com
NEXTAUTH_URL=https://hermes.your-domain.com
AUTH_SECRET=                # openssl rand -base64 32  (also accepted as NEXTAUTH_SECRET)
NEXTAUTH_SECRET=            # alias — set either AUTH_SECRET or NEXTAUTH_SECRET

# --- Google OAuth (NextAuth v5 / Auth.js) ---
# Add BOTH of these to Google Cloud Console → Authorized redirect URIs:
#   https://hermes.your-domain.com/api/auth/callback/google  (primary sign-in)
#   https://hermes.your-domain.com/api/accounts/callback     (link additional accounts)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Database (Turso / libSQL) ---
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Model providers ---
GROQ_API_KEY=               # default provider (cheap)
OPENAI_API_KEY=             # on demand
ANTHROPIC_API_KEY=          # on demand (code, long docs, Claude Skills)
NOUS_PORTAL_API_KEY=        # optional: Claude Opus via Nous Portal
OLLAMA_BASE_URL=            # optional: home Ollama via Cloudflare Tunnel for true-local privacy
MODEL_ROUTER_DEFAULT_PROVIDER=groq

# --- Skills / safety / cost ---
SKILL_REGISTRY_PATH=./skills
CLAUDE_CODE_EXECUTION=enabled   # required to run Claude Skills via the API
MONTHLY_BUDGET_CAP=10
TOKEN_ENCRYPTION_KEY=           # encrypt stored OAuth tokens at rest

# --- Cron + notifications ---
CRON_SECRET=                # openssl rand -hex 16 ; guards /api/cron/*
TELEGRAM_BOT_TOKEN=         # optional: notify via Telegram
