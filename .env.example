# Hermes OS environment variables
# Set actual secrets in Vercel Project Settings or in your untracked .env.local file.
# NEVER commit real values.

# --- App / domain ---
HERMES_DOMAIN=hermes.your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Local worker target. Production example: https://www.parawi.com
HERMES_WORKER_API_BASE_URL=
HERMES_LOCAL_PROJECTS_ROOT=  # canonical local projects root on the build machine, e.g. C:\Users\osman\OneDrive\Desktop\HermesProject
HERMES_WORKER_EMAIL_POLL_MS= # how often the always-on local worker triggers /api/cron/email-watcher (default 180000 = 3 min; 0 disables)
HERMES_AGENT_TIMEOUT_MS=1200000
NEXTAUTH_URL=https://hermes.your-domain.com
AUTH_SECRET=                # openssl rand -base64 32  (also accepted as NEXTAUTH_SECRET)
NEXTAUTH_SECRET=            # alias — set either AUTH_SECRET or NEXTAUTH_SECRET

# --- Google OAuth (NextAuth v5 / Auth.js) ---
# Add BOTH of these to Google Cloud Console → Authorized redirect URIs:
#   https://hermes.your-domain.com/api/auth/callback/google  (primary sign-in)
#   https://hermes.your-domain.com/api/accounts/callback     (link additional accounts)
# Scopes requested depend on the app configuration. Keep least-privilege scopes.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Database (Turso / libSQL) ---
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Model providers and Model Council ---
# Existing fast/low-cost fallback
GROQ_API_KEY=

# OpenAI / ChatGPT API. ChatGPT subscription and API billing may be separate.
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=

# DeepSeek hosted API. Start with the hosted API rather than a local DeepSeek model.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=

# Ollama Local Reviewer.
# Set these only in the Windows machine's .env.local where the local worker runs.
# Do NOT put localhost here in Vercel; Vercel cannot reach your personal computer.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_MODEL_FAMILY=qwen

# Existing optional providers
SAKANA_API_KEY=
FUGU_DESIGN_PASS_SCORE=7
FUGU_DESIGN_GATE_MODE=required
NOUS_PORTAL_API_KEY=
MODEL_ROUTER_DEFAULT_PROVIDER=groq

# Future model-council preferences. Safe to leave blank until Setup Center is built.
COUNCIL_ROUTING_MODE=auto
COUNCIL_ARCHITECTURE_MODEL=
COUNCIL_STRATEGY_MODEL=
COUNCIL_ENGINEERING_MODEL=
COUNCIL_CHALLENGER_MODEL=
COUNCIL_LOCAL_REVIEWER_MODEL=
COUNCIL_RESEARCH_MODEL=

# --- Skills / safety / cost ---
SKILL_REGISTRY_PATH=./skills
CLAUDE_CODE_EXECUTION=enabled   # required to run Claude Skills via the API
MONTHLY_BUDGET_CAP=10
TOKEN_ENCRYPTION_KEY=           # encrypt stored OAuth tokens at rest

# --- Cron + notifications ---
CRON_SECRET=                    # openssl rand -hex 16 ; guards /api/cron/*
TELEGRAM_BOT_TOKEN=             # Telegram bot token (BotFather)
TELEGRAM_OWNER_CHAT_ID=         # your personal Telegram chat ID (get from @userinfobot)
TELEGRAM_WEBHOOK_SECRET=        # openssl rand -hex 16 ; guards /api/telegram/webhook

# --- Job boards + enrichment ---
JSEARCH_API_KEY=                # RapidAPI → JSearch (200 req/month free)
FIRECRAWL_API_KEY=              # Firecrawl — enriches thin job descriptions
HUNTER_IO_API_KEY=              # Hunter.io recruiter email lookup (25/month free tier)

# --- Feature flags ---
HERMES_EXECUTION_ENABLED=       # set to "true" to activate the Hermes execution layer
HERMES_FUGU_GATE_MODE=recommended # off | recommended (default) | required
PARAWI_MCP_API_KEY=             # guards /api/hermes/execute (optional, for MCP callers)
HERMES_BRIDGE_KEY=              # guards /api/hermes-bridge — used by the Claude Code MCP (hermes-os); NEVER commit a real value

# --- Mercury (external tool / MCP agent) ---
# Each key unlocks a specific Mercury tool. All optional — Mercury reports
# "not connected" for any tool whose key is missing.
SERPAPI_API_KEY=                # Google Flights search via SerpAPI (serpapi.com) — free tier available
SERPER_API_KEY=                 # Web search via Serper (serper.dev) — $50/100k searches
OPENWEATHER_API_KEY=            # Weather lookups (openweathermap.org/api) — free tier available
AMADEUS_CLIENT_ID=              # Flight + hotel search (developers.amadeus.com) — free test tier
AMADEUS_CLIENT_SECRET=          # Paired with AMADEUS_CLIENT_ID
GOOGLE_MAPS_API_KEY=            # Places / location search (console.cloud.google.com → Places API)
# Note: GOOGLE_MAPS_API_KEY is a separate key from AUTH_GOOGLE_ID/SECRET (OAuth).
# Create it in Google Cloud Console → APIs & Services → Credentials → API key,
# then restrict it to the Places API only.

# --- Code execution + GitHub persistence (Prometheus agent) ---
E2B_API_KEY=                    # E2B cloud sandbox — e2b.dev (free tier: 100 hours/month)
GITHUB_TOKEN=                   # Personal access token (repo scope) — github.com/settings/tokens
# Prometheus uses this to push built apps to a repository.
# Without this key, Prometheus still works but cannot write to GitHub.

# --- Other ---
YOUTUBE_API_KEY=                # Sophos skill-scout video digest (optional)
